#!/bin/bash
# pre-push hook

# Farben für Output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "======================================================"
echo "🛡️ PRE-PUSH HOOK: Starte Tests & Security-Scans..."
echo "======================================================"

# 1. Go Tests
echo "[1/4] Führe Go Tests aus..."
if go test ./...; then
    echo -e "${GREEN}✓ Go Tests bestanden.${NC}"
else
    echo -e "${RED}✗ Go Tests fehlgeschlagen! Push abgebrochen.${NC}"
    exit 1
fi

# 2. npm audit (Frontend Dependency Security)
echo "[2/4] Führe npm audit (Frontend) aus..."
cd frontend || exit 1
if npm audit; then
    echo -e "${GREEN}✓ npm audit bestanden.${NC}"
else
    echo -e "${YELLOW}⚠ npm audit hat Schwachstellen gefunden! Bitte prüfen (Push geht weiter, da audit oft false-positives hat).${NC}"
fi
cd ..

# 3. govulncheck (Backend Dependency Security)
echo "[3/4] Führe govulncheck (Backend) aus..."
if command -v govulncheck &> /dev/null; then
    if govulncheck ./...; then
        echo -e "${GREEN}✓ govulncheck bestanden.${NC}"
    else
        echo -e "${RED}✗ govulncheck fehlgeschlagen! Kritische Backend-Schwachstellen gefunden.${NC}"
        exit 1
    fi
else
    echo -e "${YELLOW}⚠ govulncheck nicht installiert. Überspringe Scan. (go install golang.org/x/vuln/cmd/govulncheck@latest)${NC}"
fi

# 4. Trivy (Container Security)
echo "[4/4] Führe Trivy (Container) aus..."
if command -v trivy &> /dev/null; then
    if [ -f "Dockerfile" ]; then
        if trivy config Dockerfile; then
            echo -e "${GREEN}✓ Trivy Config Scan bestanden.${NC}"
        else
            echo -e "${RED}✗ Trivy Config Scan fehlgeschlagen! Dockerfile weist Fehler auf.${NC}"
            exit 1
        fi
    else
        echo -e "${YELLOW}⚠ Kein Dockerfile gefunden. Überspringe Trivy Scan.${NC}"
    fi
else
    echo -e "${YELLOW}⚠ trivy nicht installiert. Überspringe Scan.${NC}"
fi

echo -e "${GREEN}✅ Alle Pre-Push Checks bestanden! Code wird gepusht.${NC}"
exit 0

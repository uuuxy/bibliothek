# Bibliotheks-System Environment Variables
# Copy this file to .env and fill in the values

# Server configuration
PORT=8081
COOKIE_SECURE=false
# Zeitzone des Servers/Containers. Fristen-Berechnungen pinnen Europe/Berlin
# bereits im Code; TZ hier hält darüber hinaus Logs/Timestamps konsistent.
TZ=Europe/Berlin

# Database configuration (für direkten `go run`-Betrieb gegen ein lokales Postgres)
DATABASE_URL=postgres://postgres:postgrespassword@localhost:5433/bibliothek?sslmode=disable

# ── Docker-Compose-Stack (docker-compose.yml / docker-compose.local.yml) ──
# Diese Werte substituiert Docker Compose für den Postgres-Container und die daraus
# gebaute DATABASE_URL. POSTGRES_PASSWORD ist PFLICHT — es gibt bewusst kein
# committetes Default-Passwort mehr (secrets:S6698). Für lokale Entwicklung genügt
# ein beliebiger Wert; für Produktion ein starkes, einzigartiges Passwort setzen.
# Erststart:  cp .env.example .env
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-local-dev
POSTGRES_DB=bibliothek

# Environment: "production" (Standard) oder "local"/"development".
# Steuert Cookie-Secure-Flag und Swagger-Sichtbarkeit (NICHT den Secret-Guard).
APP_ENV=production

# Harte Secret-Absicherung (Start-Verweigerung bei bekannten Default-Secrets).
# Test-/Pilotphase: false (Standard) — Stack startet auch mit Defaults.
# Vor echtem Prod-Deploy auf true setzen UND echte JWT_SECRET/APP_ENCRYPTION_KEY/
# POSTGRES_PASSWORD setzen + COOKIE_SECURE=true (hinter Caddy-HTTPS).
ENFORCE_PROD_SECRETS=false

# Security
JWT_SECRET=super-secret-key-that-is-at-least-32-bytes-long

# Initial Admin Bootstrapping (only used if users table is empty)
INITIAL_ADMIN_EMAIL=admin@bibliothek.local
INITIAL_ADMIN_PASSWORD=admin

# APP_ENCRYPTION_KEY must be exactly 32 bytes (or 64 hex characters) long
APP_ENCRYPTION_KEY=your-32-character-encryption-key

# ─────────────────────────────────────────────────────────────────────────────
# Automatische Backups (täglicher Cron-Job, jobs.RunDatabaseBackup)
# ─────────────────────────────────────────────────────────────────────────────
# ACHTUNG: Ohne BACKUP_ENCRYPTION_KEY wird der Backup-Job STILL übersprungen —
# es laufen dann KEINE automatischen Backups! Vor Go-Live zwingend setzen
# (>= 32 Zeichen). Mit genau diesem Schlüssel wird via cmd/restore-backup
# wiederhergestellt (siehe docs/resilience_and_recovery.md).
BACKUP_ENCRYPTION_KEY=
# Zielverzeichnis der verschlüsselten Backups (Standard: ./backups)
BACKUP_DIR=./backups

# Optionaler Offsite-Upload der Backups nach S3 (nur aktiv, wenn alle vier gesetzt sind)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_USE_SSL=true

# ─────────────────────────────────────────────────────────────────────────────
# Produktionsbetrieb
# ─────────────────────────────────────────────────────────────────────────────
# Erzwingt die Ziel-Domain im HTTPS-Redirect (sonst Fallback auf den Request-Host).
# Hinter Caddy-HTTPS auf die öffentliche URL setzen, z. B. https://bibliothek.schule.de
ALLOWED_ORIGIN=

# Nur für Legacy-SMTP-Server mit selbstsigniertem Zertifikat (Default: sichere Verifikation).
# SMTP_ALLOW_INSECURE_TLS=true
# Optionales Sentry-Error-Reporting.
# SENTRY_DSN=
# Empfänger der Backup-Benachrichtigungs-Mails (inventur-Backup-Modul).
# BACKUP_EMAIL_TO=


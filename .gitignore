# Dependency directories
node_modules/
frontend/node_modules/

# Build outputs
dist/
frontend/dist/
frontend/dist-ssr/

# Kompilierte Go-Binaries im Repo-Root (root-verankert, damit cmd/-Pakete unberührt bleiben)
/bibliothek
/migrate
/migrate_photos
/restore-backup

# User uploads & data
uploads/

# Environment configurations
.env
*.local
frontend/*.local

# Lokale KI-/Tool-Konfiguration (Claude Code) — maschinenspezifische Permission-Allowlist,
# nicht teamweit geteilt. Die eigentlichen Git-Hooks liegen in scripts/git-hooks/.
.claude/

# OS Metadata
.DS_Store
Thumbs.db

# Database Backups & Archives
*.sql
!schema.sql
!migrations/
!migrations/*.sql
*.zip

certs/

# Temp build, logs, and diffs
*build.log
test.log
tmp_build
*.diff
frontend_build.log
build.log

tmp/

# Generierte Security-/Lint-Scan-Reports im Repo-Root (security-scan.sh etc.).
# Kuratierte Audit-Belege unter docs/security/ bleiben bewusst versioniert.
/*_report.txt
/*_report.html
/*_report.json
*.log
!scripts/*.sql

# SonarQube-Scan-Artefakte (lokal, nicht versioniert)
.scannerwork/
/sonarqube_*.json
/issues_page_*.json
